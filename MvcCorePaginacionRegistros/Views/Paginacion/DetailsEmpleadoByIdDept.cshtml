@model ModelEmpleadosDepartamento

@{
    ViewData["Title"] = "Detalle del Empleado";
    int iddepartamento = (int)ViewData["IDDEPARTAMENTO"];
    int ultimo = (int)ViewData["ULTIMO"];
    int siguiente = (int)ViewData["SIGUIENTE"];
    int anterior = (int)ViewData["ANTERIOR"];
    int posicionActual = (int)ViewData["POSICIONACTUAL"];
}

<h2>Empleado del Departamento @iddepartamento</h2>
<p> @Model.dept.Nombre</p>
<p> @Model.dept.Localidad</p>
<h5>Registro @posicionActual de @ultimo</h5>

@if (Model != null)
{
    <div class="card mt-3">
        <div class="card-header bg-primary text-white">
            <h4>Información del Empleado</h4>
        </div>
        <div class="card-body">
            <div class="row mb-3">
                <div class="col-md-3">
                    <strong>Número de Empleado:</strong>
                </div>
                <div class="col-md-9">
                    @Model.empleados.IdEmpleado
                </div>
            </div>
            <div class="row mb-3">
                <div class="col-md-3">
                    <strong>Apellido:</strong>
                </div>
                <div class="col-md-9">
                    @Model.empleados.Apellido
                </div>
            </div>
            <div class="row mb-3">
                <div class="col-md-3">
                    <strong>Oficio:</strong>
                </div>
                <div class="col-md-9">
                    @Model.empleados.Oficio
                </div>
            </div>
            <div class="row mb-3">
                <div class="col-md-3">
                    <strong>Salario:</strong>
                </div>
                <div class="col-md-9">
                    @Model.empleados.Salario.ToString("C")
                </div>
            </div>
            <div class="row mb-3">
                <div class="col-md-3">
                    <strong>Departamento:</strong>
                </div>
                <div class="col-md-9">
                    @Model.empleados.IdDepartamento
                </div>
            </div>
        </div>
    </div>

    <div class="mt-4">
        <div class="btn-group" role="group">
            <a asp-action="DetailsEmpleadoByIdDept"
               asp-route-iddepartamento="@iddepartamento"
               asp-route-posicion="1"
               class="btn btn-outline-primary">
                Primero
            </a>

            @if (posicionActual > 1)
            {
                <a asp-action="DetailsEmpleadoByIdDept"
                   asp-route-iddepartamento="@iddepartamento"
                   asp-route-posicion="@anterior"
                   class="btn btn-primary">
                    Anterior
                </a>
            }
            else
            {
                <button class="btn btn-secondary" disabled>Anterior</button>
            }

            @if (posicionActual < ultimo)
            {
                <a asp-action="DetailsEmpleadoByIdDept"
                   asp-route-iddepartamento="@iddepartamento"
                   asp-route-posicion="@siguiente"
                   class="btn btn-primary">
                    Siguiente
                </a>
            }
            else
            {
                <button class="btn btn-secondary" disabled>Siguiente</button>
            }

            <a asp-action="DetailsEmpleadoByIdDept"
               asp-route-iddepartamento="@iddepartamento"
               asp-route-posicion="@ultimo"
               class="btn btn-outline-primary">
                Último
            </a>
        </div>
    </div>
}
else
{
    <div class="alert alert-warning mt-3">
        No se encontró el empleado en esta posición.
    </div>
}

<div class="mt-3">
    <a asp-action="Index" class="btn btn-secondary">Volver al Inicio</a>
</div>